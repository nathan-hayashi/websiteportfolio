---
/* =============================================================================
   BUTTON SECONDARY — Outlined accent-color button or link
   =============================================================================
   Renders a secondary button with an accent-color border and transparent
   background. Used for secondary actions alongside a primary button.

   How it works on the webpage:
   - Transparent background with #2563EB border and text
   - Fills with light accent tint on hover
   - Used for actions like "View on GitHub", "Download PDF"

   Props:
   - href (optional): If provided, renders as <a>. Otherwise renders <button>.

   Usage: <ButtonSecondary href="/projects">Browse Projects</ButtonSecondary>

   Coordinated changes:
   - Not currently used by any page (available for future use)
   ============================================================================= */

interface Props {
  href?: string;
}

const { href } = Astro.props;
---

{href ? (
  <a href={href} class="btn btn-secondary">
    <slot />
  </a>
) : (
  <button class="btn btn-secondary" type="button">
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: var(--space-1) var(--space-3);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    border-radius: var(--radius);
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .btn-secondary:hover {
    background: rgba(37, 99, 235, 0.06);
  }

  .btn-secondary:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
</style>
