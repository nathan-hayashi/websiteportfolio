---
/* =============================================================================
   FOOTER — Site-wide footer with build info and links
   =============================================================================
   Displays a minimal footer at the bottom of every page with:
   - Build technology credits (Astro + Cloudflare)
   - GitHub source link
   - Copyright year

   How it works on the webpage:
   - Sits at the very bottom of every page via BaseLayout
   - Subtle muted text on a clean background
   - Links open in new tabs for external destinations

   Future improvement: Add social media icon links if desired.

   Coordinated changes:
   - Used by: BaseLayout.astro (appears on every page)
   - To update footer links → edit this file directly
   ADD: To add social media icons, add them inside the .footer-content div below.
   ============================================================================= */

/* Get the current year for the copyright notice */
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" data-pagefind-ignore>
  <div class="footer-content">
    <p>
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      &middot; Deployed on <a href="https://pages.cloudflare.com" target="_blank" rel="noopener noreferrer">Cloudflare</a>
      &middot; <a href="https://github.com/nathan-hayashi" target="_blank" rel="noopener noreferrer">Source on GitHub</a>
    </p>
    <p class="copyright">&copy; {currentYear} Nathan Lim</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-2);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer-content {
    max-width: var(--page-max-width);
    margin: 0 auto;
  }

  .site-footer p {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .site-footer a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 2px;
  }

  .site-footer a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .copyright {
    margin-top: var(--space-1) !important;
  }
</style>
